{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous", "authenticated"],
      "rewrite": "https://gongdan-b5fzbtgteqd5gzfb.eastasia-01.azurewebsites.net/api/*"
    },
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{css,scss,sass,js,ts,tsx,json,png,gif,jpg,jpeg,svg,ico,woff,woff2,ttf,eot}"
    ]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff"
  }
}
