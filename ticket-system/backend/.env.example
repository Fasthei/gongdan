# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ticket_system"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=""
AZURE_SERVICE_BUS_QUEUE_NAME="ticket-events"

# Knowledge Base Agent（已部署的 Azure AI Search Agent）
KB_AGENT_URL="https://agnetdoc-cve0guf5h8eggmej.southeastasia-01.azurewebsites.net"
KB_AGENT_API_KEY=""
# Jina MCP（外部 AI 搜索）
JINA_MCP_URL="https://mcp.jina.ai/v1"
JINA_API_KEY=""
JINA_SEARCH_NUM_FAST="8"
JINA_SEARCH_NUM_DEEP="10"
JINA_PARALLEL_TIMEOUT_MS="30000"

# Daytona 沙盒（LangChain @langchain/daytona，参见 https://docs.langchain.org.cn/oss/javascript/integrations/providers/daytona ）
DAYTONA_API_KEY=""
DAYTONA_API_URL="https://app.daytona.io/api"
DAYTONA_TARGET="us"

# LLM Agent Orchestrator
# 严格使用 Azure OpenAI 标准接入（无 taiji/openai-compatible 兜底）
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
AZURE_OPENAI_API_VERSION="2025-04-01-preview"
AZURE_OPENAI_API_DEPLOYMENT_NAME="gpt-5-4"
AZURE_OPENAI_API_KEY=""
LLM_PRIMARY_MODEL="gpt-5.4"
LEARN_MCP_ENABLED="true"
LEARN_MCP_URL="https://learn.microsoft.com/api/mcp"
# 可选：指定 tools/list 返回中的具体工具名；留空则自动选择最像 search 的工具
LEARN_MCP_TOOL_NAME=""

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER_NAME="attachments"

# Teams Webhook
TEAMS_WEBHOOK_URL=""

# External Status API
EXTERNAL_STATUS_API_URL="http://20.191.156.160/status/api"
UPTIME_KUMA_API_KEY=""

# Doc Creator Agent
DOC_CREATOR_BASE_URL="http://doc-creator-agent-b0d02105-db4b3a.taijiagnet.com"
DOC_CREATOR_API_KEY=""

# App
PORT=3000
NODE_ENV=development
