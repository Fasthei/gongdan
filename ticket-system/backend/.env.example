# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ticket_system"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# 统一认证中心 (Casdoor) - 详见 docs/CASDOOR_SETUP.md
# 工单 / 销售 / 超级运营中心 共用 Casdoor `built-in` 组织的用户和角色组
CASDOOR_ENDPOINT="https://casdoor.ashyglacier-8207efd2.eastasia.azurecontainerapps.io"
CASDOOR_CLIENT_ID="5ffdddd7b36f45e456e1"
CASDOOR_CLIENT_SECRET=""
CASDOOR_ORGANIZATION="built-in"
CASDOOR_APPLICATION="ticket-platform"
# 必须与前端回调页一致，且在 Casdoor Application 的 Redirect URLs 白名单里
# 已内置的白名单包含 localhost:5173/3000/4173 + 所有 *.azurestaticapps.net
CASDOOR_REDIRECT_URI="http://localhost:5173/staff/auth/callback"

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=""
AZURE_SERVICE_BUS_QUEUE_NAME="ticket-events"

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER_NAME="attachments"

# Teams Webhook
TEAMS_WEBHOOK_URL=""

# External Status API
EXTERNAL_STATUS_API_URL="http://20.191.156.160/status/api"
UPTIME_KUMA_API_KEY=""

# App
PORT=3000
NODE_ENV=development
