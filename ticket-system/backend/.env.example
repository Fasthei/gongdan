# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ticket_system"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=""
AZURE_SERVICE_BUS_QUEUE_NAME="ticket-events"

# Knowledge Base Agent（已部署的 Azure AI Search Agent）
KB_AGENT_URL="https://agnetdoc-cve0guf5h8eggmej.southeastasia-01.azurewebsites.net"
KB_AGENT_API_KEY=""
# aisousuo：同步 POST /api/search，流式 POST /api/search/stream
AI_SEARCH_AGENT_URL="https://aisousuo-gxe7hphbduetgqam.eastasia-01.azurewebsites.net/api"
AI_SEARCH_TOP_K_PAGES="3"
# SSE 路径，默认 /search/stream；设为 false 则仅同步 /search；设为空字符串亦仅同步
AI_SEARCH_SSE_PATH="/search/stream"

# LLM Agent Orchestrator (OpenAI-compatible endpoint)
LLM_BASE_URL="https://api.taijiaicloud.com/v1"
LLM_API_KEY=""
LLM_PRIMARY_MODEL="claude-sonnet-4-6"
LLM_FALLBACK_MODEL="gemini-3.1-flash-lite-preview"

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER_NAME="attachments"

# Teams Webhook
TEAMS_WEBHOOK_URL=""

# External Status API
EXTERNAL_STATUS_API_URL="http://20.191.156.160/status/api"

# App
PORT=3000
NODE_ENV=development
